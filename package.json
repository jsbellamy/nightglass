{
  "name": "nightglass",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:evidence": "playwright install chromium && playwright test",
    "assets:build": "python3 pipeline/acquire.py && python3 pipeline/icons/build.py && python3 pipeline/backdrops.py build",
    "assets:effects": "python3 pipeline/effects/author.py && python3 pipeline/effects/derive.py",
    "assets:verify": "python3 pipeline/test_contract.py && python3 pipeline/effects/verify.py && python3 pipeline/icons/verify.py && python3 pipeline/backdrops.py verify",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tauri-apps/cli": "^2",
    "happy-dom": "^20",
    "typescript": "~5.6",
    "vite": "^6",
    "vitest": "^4"
  }
}
